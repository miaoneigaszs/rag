# 基础运行配置
EMBED_PROVIDER=proxy
PROXY_API_KEY=sf-your-key
PROXY_BASE_URL=https://api.siliconflow.cn/v1
PROXY_EMBED_MODEL=BAAI/bge-large-zh-v1.5
EMBED_DIM=1024
EMBED_MAX_CHARS=450

RERANKER_API_KEY=sf-your-key
RERANKER_BASE_URL=https://api.siliconflow.cn/v1
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TRUST_ENV=true

QDRANT_MODE=local
QDRANT_PATH=./qdrant_data
QDRANT_COLLECTION=rag_docs

RAG_MODE=advanced
USE_CONTEXTUAL_RETRIEVAL=false
CONTEXTUAL_CACHE_BACKEND=disk
CONTEXTUAL_CACHE_DIR=./contextual_cache
CONTEXTUAL_CACHE_TTL=0

# 如果使用 OpenAI 官方 embedding，请改成：
# EMBED_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=text-embedding-3-small

# 如果启用 Redis 缓存：
# CONTEXTUAL_CACHE_BACKEND=redis
# CONTEXTUAL_CACHE_REDIS_URL=redis://localhost:6379/0

# 如果启用多模态图片描述：
# VISION_ENABLED=true
# VISION_API_KEY=sk-your-key
# VISION_BASE_URL=https://api.openai.com/v1
# VISION_MODEL=gpt-4o-mini
# VISION_TIMEOUT_SECONDS=15
